<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="color-scheme" content="dark" />
<title>DUMHAWK — Only Floofs &amp; Paws vs Claws</title>
<meta name="description" content="DUMHAWK makes cute iOS apps. Only Floofs is an endless feed of the internet's cutest pets. Paws vs Claws is a fast dogs vs cats arcade game." />
<meta property="og:title" content="Only Floofs — where pets become famous" />
<meta property="og:description" content="An endless scroll of the cutest pets. Heart your favorites, follow the floofs you love, and make your own pet a star." />
<meta property="og:type" content="website" />
<meta property="og:url" content="https://dumhawk.com/" />
<meta property="og:image" content="https://dumhawk.com/assets/floofs/loki-main.jpg" />
<meta name="twitter:card" content="summary_large_image" />
<style>
  * { box-sizing: border-box; }
  html,body { margin:0; background:#0b0b0f; }
  body { font:16px/1.6 -apple-system,BlinkMacSystemFont,"SF Pro Text","Segoe UI",Roboto,Helvetica,Arial,sans-serif; color:#f2f2f7; }
  a { color:#c9b8ff; text-decoration:none; } a:hover { text-decoration:underline; }
  .wrap { max-width:1060px; margin:0 auto; padding:0 22px; }
  header { display:flex; align-items:center; justify-content:space-between; padding:22px 0; }
  .brand { font-weight:800; letter-spacing:.5px; color:#fff; }
  nav a { color:#cfcfda; margin-left:20px; font-weight:600; }
  .appstore img { height:54px; width:auto; }
  .btn { display:inline-block; font-weight:700; padding:14px 24px; border-radius:999px; }
  .btn-ghost { border:1px solid #34343f; color:#fff; } .btn-ghost:hover { background:#16161c; text-decoration:none; }
  .pill { display:inline-block; font-size:12px; font-weight:700; letter-spacing:.5px; text-transform:uppercase;
          padding:5px 13px; border-radius:999px; color:#fff; background:linear-gradient(90deg,#db3eb1,#41B6E6); margin-bottom:18px; }

  /* Only Floofs hero — app screenshots are the star */
  .hero { position:relative; overflow:hidden; border-radius:30px; margin:14px 0 18px; border:1px solid #2a2233;
          background:linear-gradient(180deg,#db3eb1 0%,#41B6E6 100%); padding:52px 44px 0; }
  .hero-grid { display:grid; grid-template-columns:1fr 1fr; gap:30px; align-items:end; }
  .hero h1 { font-size:64px; line-height:1.0; margin:0 0 14px; letter-spacing:-2px; color:#fff; }
  .hero p { font-size:20px; color:#d7d7e0; margin:0 0 26px; max-width:30ch; }
  .cta { display:flex; flex-wrap:wrap; gap:14px; align-items:center; margin-bottom:52px; }
  .phones { position:relative; height:560px; }
  .phones img { position:absolute; bottom:-1px; filter:drop-shadow(0 18px 40px rgba(0,0,0,.5)); }
  .phones .back { width:54%; left:6%; transform:rotate(-7deg); opacity:.96; }
  .phones .front { width:60%; right:4%; }

  /* Screenshot strip */
  .shots { display:flex; gap:18px; justify-content:center; flex-wrap:wrap; margin:26px 0 34px; }
  .shots img { width:210px; filter:drop-shadow(0 12px 30px rgba(0,0,0,.45)); }

  /* Paws vs Claws (secondary) */
  .sub { font-size:13px; text-transform:uppercase; letter-spacing:.5px; color:#8e8e9a; font-weight:700; margin:8px 0 12px; }
  .pvc { display:flex; gap:22px; align-items:center; background:#15151b; border:1px solid #23232c; border-radius:22px; padding:24px 26px; margin:0 0 30px; }
  .pvc img.icon { width:88px; height:88px; border-radius:20px; }
  .pvc h2 { margin:0 0 4px; font-size:23px; color:#fff; } .pvc p { margin:0 0 10px; color:#b6b6c2; }
  footer { color:#8e8e9a; font-size:13px; padding:20px 0 56px; } footer a { color:#a9a9b8; }
  @media (max-width:820px){
    .hero { padding:34px 22px 0; } .hero-grid { grid-template-columns:1fr; gap:6px; }
    .hero h1 { font-size:48px; } .cta { margin-bottom:26px; } .phones { height:430px; } .pvc { flex-direction:column; text-align:center; }
  }
</style>
</head>
<body>
<div class="wrap">
  <header>
    <span class="brand">DUMHAWK</span>
    <nav><a href="#apps">Apps</a><a href="https://dumhawk.com/support.html">Support</a></nav>
  </header>

  <section class="hero" id="apps">
    <div class="hero-grid">
      <div>
        <span class="pill">Featured app</span>
        <h1>Only Floofs</h1>
        <p>An endless scroll of the internet's cutest pets. Heart your favorites, follow the floofs you love, and make your own pet famous.</p>
        <div class="cta">
          <a class="appstore" href="https://apps.apple.com/app/only-floofs/id6781334218" aria-label="Download Only Floofs on the App Store">
            <img src="https://tools.applemediaservices.com/api/badges/download-on-the-app-store/black/en-us?size=250x83" alt="Download on the App Store" height="54">
          </a>
          <a class="btn btn-ghost" href="https://dumhawk.com/only-floofs/">Learn more</a>
        </div>
      </div>
      <div class="phones">
        <img class="back" src="https://dumhawk.com/assets/floofs/phone-profile.png" alt="Only Floofs pet profile">
        <img class="front" src="https://dumhawk.com/assets/floofs/phone-swipe-deck.png" alt="Only Floofs swipe deck">
      </div>
    </div>
  </section>

  <div class="shots">
    <img src="https://dumhawk.com/assets/floofs/phone-scroll-feed.png" alt="Only Floofs feed">
    <img src="https://dumhawk.com/assets/floofs/phone-explore-grid.png" alt="Only Floofs explore grid">
    <img src="https://dumhawk.com/assets/floofs/phone-leaderboard.png" alt="Only Floofs leaderboard">
    <img src="https://dumhawk.com/assets/floofs/phone-pet-of-the-day.png" alt="Only Floofs pet of the day">
  </div>

  <div class="sub">Also from DUMHAWK</div>
  <section class="pvc">
    <img class="icon" src="https://dumhawk.com/assets/app-icon.png" alt="Paws vs Claws app icon">
    <div style="flex:1">
      <h2>Paws vs Claws</h2>
      <p>Pick your side (dogs or cats) and hop your way to glory. Quick, chaotic, and cute.</p>
      <a class="btn btn-ghost" href="https://apps.apple.com/us/app/paws-vs-claws/id6759199023">View on the App Store</a>
    </div>
  </section>

  <footer>
    © DUMHAWK ·
    <a href="https://dumhawk.com/only-floofs/">Only Floofs</a> ·
    <a href="https://apps.apple.com/us/app/paws-vs-claws/id6759199023">Paws vs Claws</a> ·
    <a href="https://dumhawk.com/support.html">Support</a>
  </footer>
</div>
</body>
</html>
